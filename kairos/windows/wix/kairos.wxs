<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
   <Package Name="Kairos" UpgradeCode="87c21c74-dbd5-4584-89d5-46d9cd0c40a7" Language="1033" Codepage="1252" Version="0.18.0-dev" Manufacturer="Kairos" InstallerVersion="200">
      <MajorUpgrade AllowSameVersionUpgrades="yes" DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
      <Icon Id="KairosIco" SourceFile=".\kairos\windows\kairos.ico" />
      <WixVariable Id="WixUILicenseRtf" Value=".\kairos\windows\wix\license.rtf" />
      <Property Id="ARPPRODUCTICON" Value="KairosIco" />
      <MediaTemplate EmbedCab="yes" />
      <ui:WixUI Id="WixUI_Minimal" />
      <Feature Id="ProductFeature" Title="ConsoleApp" Level="1">
         <ComponentRef Id="KairosExe" />
         <ComponentRef Id="KairosShortcut" />
         <ComponentRef Id="ModifyPathEnv" />
         <ComponentRef Id="ContextMenu" />
         <ComponentRef Id="ContextMenuFolder" />
      </Feature>
      <!-- Application binaries -->
      <DirectoryRef Id="KairosProgramFiles">
         <Component Id="KairosExe">
            <File Id="KairosExeFile" Source=".\target\release\kairos.exe" Name="kairos.exe" KeyPath="yes" />
         </Component>
      </DirectoryRef>
      <DirectoryRef Id="KairosProgramMenu">
         <!-- Application shortcut -->
         <Component Id="KairosShortcut" Guid="aa36e61a-23cd-4383-b744-2f78e912f0dc">
            <Shortcut Id="KairosShortcutFile" Name="Kairos" Description="A cross-platform, GPU-accelerated terminal emulator" Target="[KairosProgramFiles]kairos.exe" />
            <RemoveFolder Id="KairosProgramMenu" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\Microsoft\Kairos" Name="installed" Type="integer" Value="1" KeyPath="yes" />
         </Component>
      </DirectoryRef>
      <DirectoryRef Id="KairosProgramFiles">
         <!-- Add to PATH -->
         <Component Id="ModifyPathEnv" Guid="edf0b679-9eb6-46f7-a5d1-5160f30acb34" KeyPath="yes">
            <Environment Id="PathEnv" Value="[KairosProgramFiles]" Name="PATH" Permanent="no" Part="first" Action="set" System="yes" />
         </Component>
      </DirectoryRef>
      <StandardDirectory Id="ProgramFiles64Folder">
         <Directory Id="KairosProgramFiles" Name="Kairos" />
      </StandardDirectory>
      <StandardDirectory Id="ProgramMenuFolder">
         <Directory Id="KairosProgramMenu" Name="Kairos" />
      </StandardDirectory>
      <!-- Add context menu -->
      <Component Id="ContextMenu" Guid="449f9121-f7b9-41fe-82da-52349ea8ff91" Directory="TARGETDIR">
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\Background\shell\Open Kairos here\command">
            <RegistryValue Type="string" Value='[KairosProgramFiles]kairos.exe --working-directory "%v"' KeyPath="yes" />
         </RegistryKey>
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\Background\shell\Open Kairos here">
            <RegistryValue Type="string" Name="Icon" Value="[KairosProgramFiles]kairos.exe" />
         </RegistryKey>
      </Component>
      <Component Id="ContextMenuFolder" Guid="69483b38-a267-433f-9395-60827963347a" Directory="TARGETDIR">
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\shell\Open Kairos here\command">
            <RegistryValue Type="string" Value='[KairosProgramFiles]kairos.exe --working-directory "%v"' KeyPath="yes" />
         </RegistryKey>
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\shell\Open Kairos here">
            <RegistryValue Type="string" Name="Icon" Value="[KairosProgramFiles]kairos.exe" />
         </RegistryKey>
      </Component>
   </Package>
</Wix>
